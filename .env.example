OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional cost estimation rates in USD per 1M tokens.
# Keep these updated from your provider's pricing page.
# Local fallback runs always report 0 tokens and $0.00.
OPENAI_INPUT_COST_PER_1M_TOKENS=0
OPENAI_OUTPUT_COST_PER_1M_TOKENS=0

VECTOR_STORE=local
INSTALL_CHROMA=false
VITE_API_BASE_URL=http://localhost:8000

# Query history database.
# Defaults to a local SQLite file when unset.
# Docker Compose uses PostgreSQL:
#   DATABASE_URL=postgresql://rag:rag@postgres:5432/rag_history
DATABASE_URL=

# Comma-separated list of allowed CORS origins.
# Local default works out of the box.
# In production set this to your frontend URL, e.g.:
#   ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Pipeline engine: "langgraph" (default) or "linear"
PIPELINE_ENGINE=langgraph
